@startuml seq_login

title Sequence Diagram - Login

skinparam sequenceArrowThickness 2
skinparam BoxPadding 10
skinparam ParticipantPadding 10

actor "User\n(Student / Staff)" as U
participant "LoginFrame" as LF
participant "AuthService" as AS
participant "UserRepository" as UR
participant "User\n(StudentUser /\nStaffUser / FYP)" as USR
participant "MainFrame" as MF

U -> LF : enter userId + password
activate LF
LF -> LF : validate non-empty input
LF -> AS : authenticate(userId, password)
activate AS
AS -> UR : findByUserIdAndPassword(userId, password)
activate UR
UR -> UR : SELECT * FROM users WHERE user_id=? AND password=?
UR --> AS : ResultSet row / null
deactivate UR

alt credentials match AND status = ACTIVE
  AS -> USR : new StudentUser / StaffUser /\n FinalYearStudentUser(role)
  AS -> AS : currentUser = user
  AS --> LF : return User
  LF -> LF : dispose()
  LF -> MF : new MainFrame(user).setVisible(true)
  activate MF
  MF --> U : show tabbed UI
else invalid credentials OR INACTIVE
  AS --> LF : return null
  LF --> U : show error dialog
end

deactivate AS
deactivate MF

@enduml