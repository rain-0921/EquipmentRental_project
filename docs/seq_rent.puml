@startuml seq_rent

title Sequence Diagram - Rent Equipment

skinparam sequenceArrowThickness 2
skinparam BoxPadding 10
skinparam ParticipantPadding 10

actor "Student" as U
participant "RentalPanel" as RP
participant "RentalService" as RS
participant "EquipmentRepository" as ER
participant "RentalRepository" as RR
participant "Equipment" as EQ
participant "Rental" as R

U -> RP : select equipment + enter days
activate RP
RP -> RP : validate days > 0
RP -> RS : rentEquipment(equipmentId, currentUser, days)
activate RS
RS -> ER : getEquipment(equipmentId)
activate ER
ER -> ER : SELECT * FROM equipment WHERE id=?
ER --> RS : Equipment  (or null)
deactivate ER

alt equipment null OR status != AVAILABLE
  RS --> RP : "Equipment not available"
  RP --> U : show error
else equipment available
  RS -> RR : generateRentalId()
  activate RR
  RR -> RR : UPDATE counters SET counter_value=+1\nSELECT counter_value
  RR --> RS : "R-YYYY-NNNN"
  deactivate RR

  RS -> R : new Rental(rentalId, user, equipment, days)
  activate R
  R -> R : rentalDate = today\ndueDate = today+days\nstatus = ACTIVE
  R --> RS : Rental
  deactivate R

  RS -> RR : addRental(rental)
  activate RR
  RR -> RR : INSERT INTO rentals (...)
  RR --> RS : ok
  deactivate RR

  RS -> ER : updateStatus(equipmentId, RENTED)
  activate ER
  ER -> ER : UPDATE equipment SET status='RENTED'
  ER --> RS : ok
  deactivate ER

  RS --> RP : "SUCCESS:R-YYYY-NNNN"
  RP -> RP : loadAvailableEquipment()
  RP --> U : show success message
end

deactivate RS
deactivate RP

note right of EQ
  Polymorphism:
  Equipment subclass (Electronics /
  MediaEquipment / LaboratoryEquipment)
  is created by the repository based
  on category and stored in DB.
end note

@enduml